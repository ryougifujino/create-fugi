{
  "name": "mono-node",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "commitlint": "commitlint",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint-staged": "lint-staged",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,html,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
