{
  "name": "mono-hono-react",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:web": "pnpm --filter @mono-hono-react/web dev",
    "dev:server": "pnpm --filter @mono-hono-react/server dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @mono-hono-react/server start",
    "preview": "pnpm --filter @mono-hono-react/web preview",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "stylelint": "stylelint \"apps/**/*.{css,scss}\"",
    "stylelint:fix": "pnpm stylelint --fix \"apps/**/*.{css,scss}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint",
    "prepare": "lefthook install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript-eslint": "^8.60.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "catalog:"
    },
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
